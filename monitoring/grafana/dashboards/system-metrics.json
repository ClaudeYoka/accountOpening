{
  "dashboard": {
    "id": null,
    "title": "Account Opening - Métriques Système",
    "tags": ["account-opening", "system"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Utilisation CPU",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "refId": "A",
            "legendFormat": "CPU Usage %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Utilisation Mémoire",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
            "refId": "A",
            "legendFormat": "Memory Usage %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Utilisation Disque",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
            "refId": "A",
            "legendFormat": "Disk Usage %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Charge Système",
        "type": "graph",
        "targets": [
          {
            "expr": "node_load1",
            "refId": "A",
            "legendFormat": "Load 1min"
          },
          {
            "expr": "node_load5",
            "refId": "B",
            "legendFormat": "Load 5min"
          },
          {
            "expr": "node_load15",
            "refId": "C",
            "legendFormat": "Load 15min"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Mémoire PHP",
        "type": "graph",
        "targets": [
          {
            "expr": "php_memory_usage_bytes / 1024 / 1024",
            "refId": "A",
            "legendFormat": "Memory Usage (MB)"
          },
          {
            "expr": "php_memory_peak_usage_bytes / 1024 / 1024",
            "refId": "B",
            "legendFormat": "Peak Memory (MB)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 6,
        "title": "Temps de réponse HTTP",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_request_duration_milliseconds_sum[5m]) / rate(http_request_duration_milliseconds_count[5m])",
            "refId": "A",
            "legendFormat": "Avg Response Time (ms)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 7,
        "title": "Requêtes HTTP",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "refId": "A",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 8,
        "title": "MySQL - Connexions actives",
        "type": "graph",
        "targets": [
          {
            "expr": "mysql_global_status_threads_connected",
            "refId": "A",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        }
      },
      {
        "id": 9,
        "title": "MySQL - Requêtes par seconde",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(mysql_global_status_queries[5m])",
            "refId": "A",
            "legendFormat": "Queries/sec"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 10,
        "title": "MySQL - InnoDB Buffer Pool",
        "type": "graph",
        "targets": [
          {
            "expr": "mysql_global_status_innodb_buffer_pool_pages_total - mysql_global_status_innodb_buffer_pool_pages_free",
            "refId": "A",
            "legendFormat": "Used Pages"
          },
          {
            "expr": "mysql_global_status_innodb_buffer_pool_pages_total",
            "refId": "B",
            "legendFormat": "Total Pages"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}