{
  "dashboard": {
    "id": null,
    "title": "Account Opening - Vue d'ensemble",
    "tags": ["account-opening", "overview"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Statut de l'application",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"account-opening-app\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Connexion Base de données",
        "type": "stat",
        "targets": [
          {
            "expr": "db_connection_status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Utilisateurs actifs (dernière heure)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_active_sessions",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Total utilisateurs",
        "type": "stat",
        "targets": [
          {
            "expr": "app_total_users",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Comptes clients",
        "type": "bargauge",
        "targets": [
          {
            "expr": "app_total_accounts",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 6,
        "title": "Demandes de chéquiers",
        "type": "piechart",
        "targets": [
          {
            "expr": "app_pending_chequier_requests",
            "refId": "A",
            "legendFormat": "En cours"
          },
          {
            "expr": "app_completed_chequier_requests",
            "refId": "B",
            "legendFormat": "Livrées"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 7,
        "title": "Soumissions de formulaires (aujourd'hui)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_form_submissions_today",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 0,
          "y": 10
        }
      },
      {
        "id": 8,
        "title": "Connexions réussies (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_successful_logins_24h",
            "refId": "A"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 8,
          "y": 10
        }
      },
      {
        "id": 9,
        "title": "Échecs de connexion (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_failed_logins_24h",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 16,
          "y": 10
        }
      },
      {
        "id": 10,
        "title": "Notifications non lues",
        "type": "stat",
        "targets": [
          {
            "expr": "app_pending_notifications",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 0,
          "y": 14
        }
      },
      {
        "id": 11,
        "title": "Erreurs récentes (1h)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_recent_errors",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 12,
          "y": 14
        }
      },
      {
        "id": 12,
        "title": "Taille base de données",
        "type": "stat",
        "targets": [
          {
            "expr": "app_database_size_mb",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "MB"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 0,
          "y": 18
        }
      },
      {
        "id": 13,
        "title": "Uptime application",
        "type": "stat",
        "targets": [
          {
            "expr": "app_uptime_seconds",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 12,
          "y": 18
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}