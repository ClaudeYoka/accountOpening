{
  "dashboard": {
    "id": null,
    "title": "Account Opening - Sécurité",
    "tags": ["account-opening", "security"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Échecs de connexion (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_failed_logins_24h",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Connexions réussies (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "app_successful_logins_24h",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 8,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Taux de succès des connexions",
        "type": "stat",
        "targets": [
          {
            "expr": "(app_successful_logins_24h / (app_successful_logins_24h + app_failed_logins_24h)) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 80
                },
                {
                  "color": "green",
                  "value": 95
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 16,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Évolution des échecs de connexion",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(app_failed_logins_24h[1h])",
            "refId": "A",
            "legendFormat": "Failed Logins"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 5,
        "title": "Évolution des connexions réussies",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(app_successful_logins_24h[1h])",
            "refId": "A",
            "legendFormat": "Successful Logins"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 6,
        "title": "Erreurs système récentes",
        "type": "table",
        "targets": [
          {
            "expr": "app_recent_errors",
            "refId": "A",
            "format": "table"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 7,
        "title": "Sessions actives suspectes",
        "type": "stat",
        "targets": [
          {
            "expr": "app_active_sessions > 50",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "Normal",
                    "color": "green"
                  },
                  "1": {
                    "text": "Élevé",
                    "color": "orange"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 8,
        "title": "Notifications de sécurité",
        "type": "stat",
        "targets": [
          {
            "expr": "app_pending_notifications",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 25
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 12,
          "y": 20
        }
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "5m",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}