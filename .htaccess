RewriteEngine On

# Masquer .php pour les fichiers dans les sous-dossiers (Admin, head, staff, rh, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/([a-zA-Z0-9_-]+)$ $1/$2.php [L]  # Ex: /admin/dashboard → /admin/dashboard.php
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L]             # Ex: /home → /home.php