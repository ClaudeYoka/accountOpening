# .env.example - À copier et compléter avec les vraies valeurs
# NE PAS COMMITTER .env en production!

# === DATABASE ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=accountopen_user
DB_PASS=ChangeMe_SecurePassword_123!
DB_NAME=accountopening_db

# === APPLICATION ===
APP_ENV=production
APP_DEBUG=false
APP_KEY=your_random_32_char_key_here_change_me

# === SECURITY ===
# Générer avec: php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=your_32_char_hex_here
JWT_SECRET=your_jwt_secret_here_change_me

# === SESSION ===
SESSION_TIMEOUT=1800
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# === EMAIL (SMTP) ===
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@bank.app
MAIL_FROM_NAME="Account Opening"

# === API Keys ===
API_KEY=your_api_key_here_change_me
FLEXCUBE_API_KEY=your_flexcube_key_change_me

# === LOGGING ===
LOG_CHANNEL=stack
LOG_LEVEL=error

# === EXTERNAL SERVICES ===
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# === RATE LIMITING ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_API_REQUESTS_PER_MINUTE=100
